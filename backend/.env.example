MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# LLM provider — swap these three to change model/provider, no code changes needed
# Anthropic example:
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-6
# OpenAI example:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o
# Groq example:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

PORT=3001

# Fortis booking webhook — TatvaCare backend POSTs here when a patient taps "Book This Package"
# Payload: { event, patientId, sessionId, recommendedPackage, finalScores, answers, activeBranches, recommendedAt, notifiedAt }
# Replace with the real Fortis endpoint when Fortis confirms the URL
FORTIS_BOOKING_WEBHOOK=https://api.fortishealthcare.com/webhooks/tatvacare/v1/package-recommendation
