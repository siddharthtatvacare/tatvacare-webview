{
  "_note": "Engine config for the risk-domain (A) + test-coverage (C) recommendation model, per NewScoringExplained.md. Consumed by services/newScoringEngine.js. Package profiles are DERIVED at runtime from new_fortis_packages.json via testRegistry aliases — not authored here.",
  "version": "2.0",
  "model": "A_alignment_plus_C_coverage",
  "weights": {
    "wA_alignment": 0.25,
    "wC_coverage": 0.75
  },
  "formula": "fit = 100 * (wA*alignment + wC*coverage) * adequacy",
  "domains": {
    "M": "Metabolic — diabetes, glucose, insulin resistance, weight",
    "C": "Cardiac — cardiovascular risk, lipids, ischaemia, heart function",
    "O": "Onco / Age-screening — cancer screens & age-driven surveillance",
    "G": "General-Organ — liver, kidney, thyroid, nutrition, haematology",
    "X": "Gender-specific — sex-based reproductive & cancer screens"
  },
  "alignment": {
    "method": "cosine_similarity",
    "note": "cosine of patient domain vector v and package profile vector p; compares shape not size"
  },
  "coverage": {
    "note": "share of the patient's indicated needs (tests+consults) the package contains, weighted by strength x importance",
    "importanceRule": "maxDomainImportance",
    "indicationAggregation": "max",
    "indicationCap": 1.0,
    "dataGapsCountAsPresent": true
  },
  "adequacy": {
    "formula": "max(floor, 1 - slope*abs(packageBreadthTier - patientBurdenTier))",
    "slope": 0.15,
    "floor": 0.8,
    "packageBreadthTier": {
      "basic_health_package": 1,
      "silver_health_package": 2,
      "gold_health_package": 3,
      "diabetic_profile": 2.5,
      "healthy_heart_profile": 2.5
    }
  },
  "burdenTier": {
    "_note": "patient burden tier 1-3 from total domain points, nudged by Q8 depth preference (tunable).",
    "fromTotalDomainPoints": [
      {
        "upTo": 6,
        "tier": 1
      },
      {
        "upTo": 12,
        "tier": 2
      },
      {
        "upTo": 9999,
        "tier": 3
      }
    ],
    "q8Delta": {
      "q8_essentials": -0.5,
      "q8_standard": 0,
      "q8_comprehensive": 0.5
    },
    "clamp": [
      1,
      3
    ]
  },
